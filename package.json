{
  "name": "pos-terminal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "node backend/server/index.js",
    "start": "node backend/server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.pos-terminal.app",
    "productName": "POS Terminal",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "frontend/js/**/*",
      "frontend/assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POS Terminal",
      "language": "1049",
      "include": "build/installer.nsh"
    },
    "asar": false
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.0"
  }
}
